rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'mdsohanali636@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    function hasPremium() {
      return isAdmin() || (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.hasPremiumAccess == true
      );
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.class is string && data.class.size() <= 50
          && data.role in ['user', 'admin']
          && (data.hasPremiumAccess == null || data.hasPremiumAccess is bool)
          && (data.premiumExpiry == null || data.premiumExpiry is number)
          && (data.canUpload == null || data.canUpload is bool)
          && (data.uid == null || data.uid is string)
          && data.createdAt is number;
    }

    function isValidExam(data) {
      return data.title is string && data.title.size() <= 200
          && data.class is string && data.class.size() <= 50
          && data.subject is string && data.subject.size() <= 100
          && (data.chapter == null || data.chapter is string)
          && (data.chapterNameCustom == null || data.chapterNameCustom is string)
          && (data.topicIds == null || data.topicIds is list)
          && (data.isPremium == null || data.isPremium is bool)
          && (data.status == null || data.status is string)
          && data.examType in ['mcq', 'written']
          && data.totalQuestionsToShow is number
          && data.negativeMarking is bool
          && (data.negativeValue == null || data.negativeValue is number)
          && data.createdBy is string
          && data.createdAt is number;
    }

    function isValidQuestion(data) {
      return data.questionText is string && data.questionText.size() <= 2000
          && data.type in ['mcq', 'written']
          && (data.type != 'mcq' || (data.options is list && data.options.size() >= 2 && data.options.size() <= 10))
          && (data.type != 'mcq' || data.correctAnswer is number)
          && (data.topicId == null || data.topicId is string)
          && data.createdAt is number;
    }

    function isValidAttempt(data) {
      return data.userId == request.auth.uid
          && data.examId is string
          && data.answers is list
          && data.score is number
          && data.totalQuestions is number
          && data.timeTaken is number
          && data.submittedAt is number;
    }

    function isValidLeaderboard(data) {
      return data.userId == request.auth.uid
          && data.class is string
          && data.examId is string
          && data.userName is string
          && data.bestScore is number
          && data.timeTaken is number
          && data.lastUpdated is number;
    }

    function isValidAcademicClass(data) {
      return data.name is string && data.name.size() <= 100
          && data.order is number
          && data.active is bool;
    }

    function isValidAcademicSubject(data) {
      return data.classId is string
          && data.name is string && data.name.size() <= 100
          && data.order is number
          && data.active is bool;
    }

    function isValidAcademicChapter(data) {
      return data.subjectId is string
          && data.name is string && data.name.size() <= 100
          && data.order is number
          && data.active is bool;
    }

    function isValidAcademicTopic(data) {
      return data.classId is string
          && data.subjectId is string
          && data.chapterId is string
          && data.name is string && data.name.size() <= 100
          && data.order is number
          && data.active is bool
          && (data.get('tags', null) == null || data.tags is list)
          && (data.get('mcqCount', null) == null || data.mcqCount is number)
          && (data.get('writtenCount', null) == null || data.writtenCount is number);
    }

    function isValidExamTemplate(data) {
      return data.userId == request.auth.uid
          && data.name is string && data.name.size() <= 200
          && data.settings is map
          && data.createdAt is number;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() || (incoming().role == existing().role && incoming().hasPremiumAccess == existing().hasPremiumAccess)
      );
      allow delete: if isAdmin();

      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /exams/{examId} {
      allow read: if true;
      allow create: if isAdmin() && isValidExam(incoming());
      allow update: if isAdmin() && isValidExam(incoming());
      allow delete: if isAdmin();

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create, update: if isAdmin() && isValidQuestion(incoming());
        allow delete: if isAdmin();
      }
    }

    match /attempts/{attemptId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidAttempt(incoming());
    }

    match /leaderboards/{leaderboardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidLeaderboard(incoming());
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && incoming().userId == request.auth.uid)) && isValidLeaderboard(incoming());
    }

    match /contents/{id} {
      allow read: if true;
      allow create, update: if isAdmin() || (isSignedIn() && incoming().authorId == request.auth.uid && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canUpload == true);
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /playlists/{id} {
      allow read: if true;
      allow create, update: if isAdmin() || (isSignedIn() && incoming().authorId == request.auth.uid && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canUpload == true);
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /external_resources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /feedback/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /questions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /newsletter_subscribers/{id} {
      allow read: if isAdmin();
      allow create: if true; // Public signup
    }

    match /academic_classes/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidAcademicClass(incoming());
      allow update: if isAdmin() && isValidAcademicClass(incoming());
      allow delete: if isAdmin();
    }

    match /subjects/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidAcademicSubject(incoming());
      allow update: if isAdmin() && isValidAcademicSubject(incoming());
      allow delete: if isAdmin();
    }

    match /chapters/{id} {
      allow read: if true;
      allow create: if isAdmin() && isValidAcademicChapter(incoming());
      allow update: if isAdmin() && isValidAcademicChapter(incoming());
      allow delete: if isAdmin();
    }

    match /topics/{id} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidAcademicTopic(incoming());
      allow delete: if isAdmin();
    }

    match /exam_templates/{id} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidExamTemplate(incoming());
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid) && isValidExamTemplate(incoming());
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
