rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'mdsohanali636@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.name is string && data.name.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.class is string && data.class.size() <= 50
          && data.role in ['user', 'admin']
          && data.createdAt is number;
    }

    function isValidExam(data) {
      return data.title is string && data.title.size() <= 200
          && data.class is string && data.class.size() <= 50
          && data.subject is string && data.subject.size() <= 100
          && (data.chapter == null || data.chapter is string)
          && (data.chapterNameCustom == null || data.chapterNameCustom is string)
          && data.examType in ['mcq', 'written']
          && data.totalQuestionsToShow is number
          && data.negativeMarking is bool
          && data.negativeValue is number
          && data.createdBy is string
          && data.createdAt is number;
    }

    function isValidQuestion(data) {
      return data.questionText is string && data.questionText.size() <= 2000
          && data.type in ['mcq', 'written']
          && (data.type != 'mcq' || (data.options is list && data.options.size() >= 2 && data.options.size() <= 10))
          && (data.type != 'mcq' || data.correctAnswer is number)
          && data.createdAt is number;
    }

    function isValidAttempt(data) {
      return data.userId == request.auth.uid
          && data.examId is string
          && data.answers is list
          && data.score is number
          && data.totalQuestions is number
          && data.timeTaken is number
          && data.submittedAt is number;
    }

    function isValidLeaderboard(data) {
      return data.userId == request.auth.uid
          && data.class is string
          && data.examId is string
          && data.userName is string
          && data.bestScore is number
          && data.timeTaken is number
          && data.lastUpdated is number;
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUser(incoming());

      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidExam(incoming());
      allow update: if isAdmin() && isValidExam(incoming());
      allow delete: if isAdmin();

      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create, update: if isAdmin() && isValidQuestion(incoming());
        allow delete: if isAdmin();
      }
    }

    match /attempts/{attemptId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn(); // Allow any signed in user to save attempt
    }

    match /leaderboards/{leaderboardId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Allow any signed in user to create leaderboard entry
      allow update: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid); // Simplified
    }

    match /contents/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || (isSignedIn() && incoming().authorId == request.auth.uid && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canUpload == true);
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /playlists/{id} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin() || (isSignedIn() && incoming().authorId == request.auth.uid && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canUpload == true);
      allow delete: if isAdmin() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /external_resources/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /feedback/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /questions/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /newsletter_subscribers/{id} {
      allow read: if isAdmin();
      allow create: if true; // Public signup
    }
  }
}
