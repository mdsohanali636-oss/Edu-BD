rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024;
    }
    match /external_thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024;
    }
    match /resources/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.size < 500 * 1024 * 1024;
    }
  }
}
