{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "class": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "hasPremiumAccess": { "type": "boolean" },
        "premiumExpiry": { "type": "number" },
        "canUpload": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "class", "role", "hasPremiumAccess", "createdAt"]
    },
    "Bookmark": {
      "title": "User Bookmark",
      "description": "Saved content item for a user",
      "type": "object",
      "properties": {
        "contentId": { "type": "string" },
        "savedAt": { "type": "number" }
      },
      "required": ["contentId", "savedAt"]
    },
    "Exam": {
      "title": "Scalable Exam",
      "description": "Exam configuration and metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" },
        "chapter": { "type": "string" },
        "chapterNameCustom": { "type": "string" },
        "examType": { "type": "string", "enum": ["mcq", "written"] },
        "totalQuestionsToShow": { "type": "number" },
        "negativeMarking": { "type": "boolean" },
        "negativeValue": { "type": "number" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["title", "class", "subject", "examType", "createdBy", "createdAt"]
    },
    "Question": {
      "title": "Exam Question",
      "description": "Individual question in an exam pool",
      "type": "object",
      "properties": {
        "questionText": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "number" },
        "type": { "type": "string", "enum": ["mcq", "written"] },
        "createdAt": { "type": "number" }
      },
      "required": ["questionText", "type", "createdAt"]
    },
    "Attempt": {
      "title": "Exam Attempt",
      "description": "Result of a student taking an exam",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "examId": { "type": "string" },
        "answers": { "type": "array" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "timeTaken": { "type": "number" },
        "submittedAt": { "type": "number" }
      },
      "required": ["userId", "examId", "score", "totalQuestions", "submittedAt"]
    },
    "Leaderboard": {
      "title": "Leaderboard Ranking",
      "description": "Best performance per student per exam",
      "type": "object",
      "properties": {
        "class": { "type": "string" },
        "examId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "bestScore": { "type": "number" },
        "timeTaken": { "type": "number" },
        "lastUpdated": { "type": "number" }
      },
      "required": ["class", "examId", "userId", "bestScore", "timeTaken", "lastUpdated"]
    },
    "Content": {
      "title": "Study Resource",
      "description": "Notes, books, and videos",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "academicClass": { "type": "string" },
        "subject": { "type": "string" },
        "url": { "type": "string" },
        "status": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "Playlist": {
      "title": "Video Playlist",
      "description": "YouTube or custom playlists",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "number" }
      }
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "User feedback messages",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "ExternalResource": {
      "title": "External Study Tool",
      "description": "Links to external study tools or calculators",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "number" }
      }
    },
    "NewsletterSubscriber": {
      "title": "Newsletter Subscription",
      "description": "Subscriber email for newsletter",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    },
    "AcademicClass": {
      "title": "Academic Class",
      "description": "Custom academic level definition",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "number" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "order", "active"]
    },
    "AcademicSubject": {
      "title": "Academic Subject",
      "description": "Subject within a class",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["classId", "name", "order", "active"]
    },
    "AcademicChapter": {
      "title": "Academic Chapter",
      "description": "Chapter within a subject",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "subjectId": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" },
        "active": { "type": "boolean" },
        "mcqCount": { "type": "number" },
        "writtenCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["classId", "subjectId", "name", "order", "active"]
    },
    "AcademicTopic": {
      "title": "Academic Topic",
      "description": "Topic within a chapter",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "subjectId": { "type": "string" },
        "chapterId": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" },
        "active": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "mcqCount": { "type": "number" },
        "writtenCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["classId", "subjectId", "chapterId", "name", "order", "active"]
    },
    "ExamTemplate": {
      "title": "Exam Preset Template",
      "description": "Saved custom exam configuration",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "settings": { "type": "object" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "name", "settings", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/users/{userId}/bookmarks/{bookmarkId}": { "schema": "Bookmark", "description": "User bookmarks" },
    "/exams/{examId}": { "schema": "Exam", "description": "Exams configurations" },
    "/exams/{examId}/questions/{questionId}": { "schema": "Question", "description": "Questions pool for specific exam" },
    "/attempts/{attemptId}": { "schema": "Attempt", "description": "Exam attempts" },
    "/leaderboards/{leaderboardId}": { "schema": "Leaderboard", "description": "Rankings" },
    "/contents/{contentId}": { "schema": "Content", "description": "Resources" },
    "/playlists/{playlistId}": { "schema": "Playlist", "description": "Playlists" },
    "/feedback/{feedbackId}": { "schema": "Feedback", "description": "User feedback" },
    "/questions/{questionId}": { "schema": "Question", "description": "Global questions pool" },
    "/external_resources/{resourceId}": { "schema": "ExternalResource", "description": "External resource links" },
    "/newsletter_subscribers/{subscriberId}": { "schema": "NewsletterSubscriber", "description": "Newsletter subscribers" },
    "/academic_classes/{classId}": { "schema": "AcademicClass", "description": "Academic classes" },
    "/subjects/{subjectId}": { "schema": "AcademicSubject", "description": "Academic subjects" },
    "/chapters/{chapterId}": { "schema": "AcademicChapter", "description": "Academic chapters" },
    "/topics/{topicId}": { "schema": "AcademicTopic", "description": "Academic topics" },
    "/exam_templates/{templateId}": { "schema": "ExamTemplate", "description": "Custom exam templates" }
  }
}
